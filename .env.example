# ── NCBI ─────────────────────────────────────────────────────────────────
NCBI_EMAIL=your.email@institution.edu
NCBI_API_KEY=                          # optional — raises rate limit to 10 req/s

# ── Google OAuth ──────────────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console (OAuth 2.0 client)
GOOGLE_REDIRECT_URI=http://localhost:8000/api/integrations/google/callback

# ── AI APIs ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=                        # optional

# ── Backend ───────────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
REDIS_URL=redis://localhost:6379/0
DB_PATH=.tmp/wat_genomics.db
JOB_TMP_DIR=/tmp/idss_jobs

# ── Frontend ──────────────────────────────────────────────────────────────
# Set during Docker build; leave blank for local dev (Vite proxy handles it)
VITE_API_BASE_URL=
